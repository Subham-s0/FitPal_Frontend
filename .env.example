VITE_API_BASE_PATH=/api
VITE_API_PROXY_TARGET=http://localhost:9090

# Set this when the frontend should call the backend directly instead of using
# Vite's dev proxy. Example: https://api.example.com
# For phone/LAN testing, use your computer's LAN IP here instead of localhost,
# or leave it empty and rely on Vite's proxy.
VITE_BACKEND_ORIGIN=
